# Server-only Supabase credentials (never commit a filled-in .env)
# Copy to .env and replace with values from:
#   Supabase → Project Settings → API

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Optional: comma-separated extra browser origins allowed to call /api
# (localhost Expo web ports are already allowed by default in server.js)
# CORS_ORIGINS=https://app.habitstackerapp.com
